# Build artifacts - Linux and Windows MUST use separate target dirs.
# See CLAUDE.md: CARGO_TARGET_DIR=target/linux (Linux) / target/windows (Windows).
# (target/ already covers the WDK's target/<profile>/package/ output.)
/target
/**/target
target/

# WDK / driver signing artifacts
*.sys
*.pdb
*.cat
*.cer

# Assembled driver packages (tools/package/make-package.sh output)
/dist/

# Editor / OS cruft
*.swp
*~
.DS_Store
.vscode/
.idea/
System\ Volume\ Information

# Local environment overrides
.env
*.local.toml

# Windows share junk
$RECYCLE.BIN/

# Machine-specific MCP config (absolute binary path + per-machine Windows
# username). Copy .mcp.json.example or use `claude mcp add`. See README.
/.mcp.json
